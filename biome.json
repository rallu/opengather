{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"files": {
		"includes": [
			"**",
			"!.react-router",
			"!.turbo",
			"!build",
			"!test-results",
			"!node_modules",
			"!app/generated",
			"!e2e/**/*"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedFunctionParameters": "warn",
				"useExhaustiveDependencies": "warn"
			},
			"nursery": {
				"noExcessiveLinesPerFile": {
					"level": "warn",
					"options": {
						"maxLines": 400,
						"skipBlankLines": true
					}
				}
			}
		}
	}
}
