# Canonical URL for this deployment. Optional if you rely on first-run setup to save the origin; recommended for local dev (match the dev server URL).
APP_BASE_URL=http://localhost:5173
DATABASE_URL=postgres://opengather:opengather@127.0.0.1:5433/opengather
BETTER_AUTH_SECRET=opengather-dev-secret-change-me
# Optional: enable Hub integration when a Hub deployment exists.
# HUB_BASE_URL=https://hub.example.com
MEDIA_LOCAL_ROOT=./storage/media
