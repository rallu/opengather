{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "./dist",
		"rootDir": "."
	},
	"include": [
		"ui.ts",
		"post.ts",
		"rich-text.ts",
		"utils.ts",
		"shared/**/*.ts",
		"shared/**/*.tsx",
		"app/lib/utils.ts",
		"app/lib/rich-text.ts",
		"app/components/profile/profile-image.tsx",
		"app/components/ui/badge.tsx",
		"app/components/ui/button-group.tsx",
		"app/components/ui/button.tsx",
		"app/components/ui/card.tsx",
		"app/components/ui/chat-bubble.tsx",
		"app/components/ui/container.tsx",
		"app/components/ui/dialog.tsx",
		"app/components/ui/dropdown.tsx",
		"app/components/ui/feed-container.tsx",
		"app/components/ui/hero-image.tsx",
		"app/components/ui/icon-button.tsx",
		"app/components/ui/icon.tsx",
		"app/components/ui/input.tsx",
		"app/components/ui/label.tsx",
		"app/components/ui/layouts.tsx",
		"app/components/ui/media-heading.tsx",
		"app/components/ui/popover.tsx",
		"app/components/ui/selector.tsx",
		"app/components/ui/spinner.tsx",
		"app/components/ui/textarea.tsx",
		"app/components/ui/toast.tsx",
		"app/components/post/post-actions.tsx",
		"app/components/post/post-heading.tsx",
		"app/components/post/post-image-content.tsx",
		"app/components/post/post-image-gallery-content.tsx",
		"app/components/post/post-labels.tsx",
		"app/components/post/post-video-content.tsx"
	],
	"exclude": ["node_modules", "build", "dist"]
}
